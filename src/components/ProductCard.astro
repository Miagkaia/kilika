---
import type { Lang } from '../i18n/ui';
import { localizedPath } from '../lib/site';
import { title, priceLabel, type ProductEntry } from '../lib/products';

interface Props { product: ProductEntry; lang: Lang; index?: number; }
const { product, lang, index = 0 } = Astro.props;
const cat = product.data.category;
const slugPath = cat === 'bebe' ? `/bebe/${product.id}` : `/chien-chat/${product.id}`;
const href = localizedPath(slugPath, lang);
const img = product.data.images[0];
const img2 = product.data.images[1];
const name = title(product, lang);
---
<a class={`card card--${cat}`} href={href} data-reveal style={`--d:${(index % 4) * 70}ms`}>
  <div class="card__media">
    {img && <img class="card__img" src={img} alt={name} loading={index < 4 ? 'eager' : 'lazy'} width="640" height="800" />}
    {img2 && <img class="card__img card__img--hover" src={img2} alt="" aria-hidden="true" loading="lazy" />}
    <span class="card__price price">{priceLabel(product, lang)}</span>
  </div>
  <div class="card__body">
    <h3 class="card__title">{name}</h3>
    <span class="card__arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .card { display: block; transition: transform .4s cubic-bezier(.2,.8,.2,1); transition-delay: var(--d, 0ms); }
  .card:hover { transform: translateY(-6px); }
  .card__media {
    position: relative; aspect-ratio: 4 / 5; border-radius: var(--radius); overflow: hidden;
    background: var(--cream-deep); box-shadow: 0 18px 40px -28px rgba(43,36,32,.5);
  }
  .card--bebe .card__media { background: var(--bebe-soft); }
  .card--pet .card__media { background: var(--pet-soft); }
  .card__img { width: 100%; height: 100%; object-fit: cover; transition: transform .8s cubic-bezier(.2,.8,.2,1), opacity .5s; }
  .card:hover .card__img { transform: scale(1.05); }
  .card__img--hover { position: absolute; inset: 0; opacity: 0; }
  .card:hover .card__img--hover { opacity: 1; }
  .card__price {
    position: absolute; left: .8rem; bottom: .8rem; z-index: 2;
    background: var(--paper); color: var(--ink); padding: .35em .8em; border-radius: 999px;
    font-size: var(--step--1); box-shadow: 0 6px 16px -8px rgba(43,36,32,.5);
  }
  .card__body { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .9rem .2rem 0; }
  .card__title { font-size: var(--step-1); font-weight: 600; }
  .card__arrow { font-size: 1.3rem; color: var(--terracotta); transition: transform .3s; }
  .card:hover .card__arrow { transform: translateX(5px); }
</style>
