---
interface Props { tone?: 'ink' | 'cream'; }
const { tone = 'ink' } = Astro.props;
---
<span class={`logo logo--${tone}`}>
  <span class="logo__word">kilika</span>
  <svg class="logo__swoosh" viewBox="0 0 120 14" fill="none" aria-hidden="true">
    <path d="M2 9C20 3 40 11 60 7c20-4 40 2 58-3" stroke="currentColor" stroke-width="3.4" stroke-linecap="round"/>
  </svg>
</span>

<style>
  .logo { position: relative; display: inline-flex; flex-direction: column; line-height: .9; }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.6rem, 1.2rem + 1.4vw, 2.2rem);
    letter-spacing: -0.02em;
  }
  .logo--ink .logo__word { color: var(--ink); }
  .logo--cream .logo__word { color: var(--cream); }
  .logo__swoosh { width: 100%; height: .55em; margin-top: -.12em; color: var(--terracotta); }
</style>
