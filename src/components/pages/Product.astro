---
import type { Lang } from '../../i18n/ui';
import { t, ui } from '../../i18n/ui';
import { localizedPath } from '../../lib/site';
import {
  title as pTitle, desc as pDesc, priceLabel, formatPrice,
  productWaLink, relatedProducts, type ProductEntry,
} from '../../lib/products';
import ProductCard from '../ProductCard.astro';

interface Props { lang: Lang; product: ProductEntry; }
const { lang, product } = Astro.props;
const tr = t(lang);
const d = product.data;
const name = pTitle(product, lang);
const description = pDesc(product, lang);
const images = d.images.length ? d.images : [];
const waHref = productWaLink(product, lang);
const related = await relatedProducts(product, 3);
const catPath = d.category === 'bebe' ? '/bebe' : '/chien-chat';
const catLabel = d.category === 'bebe' ? tr('nav.bebe') : tr('nav.pet');
---
<nav class="crumbs wrap" aria-label="breadcrumb">
  <a href={localizedPath('/', lang)}>{tr('nav.home')}</a>
  <span aria-hidden="true">/</span>
  <a href={localizedPath(catPath, lang)}>{catLabel}</a>
  <span aria-hidden="true">/</span>
  <span class="crumbs__current">{name}</span>
</nav>

<section class="section product">
  <div class="wrap product__grid">
    <!-- Gallery -->
    <div class="gallery">
      <div class="gallery__main">
        <img id="gallery-main" src={images[0]} alt={name} width="800" height="800" loading="eager" />
      </div>
      {images.length > 1 && (
        <ul class="gallery__thumbs">
          {images.map((img, i) => (
            <li>
              <button class={`thumb ${i === 0 ? 'is-active' : ''}`} data-src={img} aria-label={`${name} ${i + 1}`}>
                <img src={img} alt="" width="120" height="120" loading="lazy" />
              </button>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Info -->
    <div class="info">
      <span class={`info__cat info__cat--${d.category}`}>{catLabel}</span>
      <h1 class="info__title">{name}</h1>
      <p class="info__price price">{priceLabel(product, lang)}</p>
      <p class="info__desc">{description}</p>

      {d.sizes.length > 0 && (
        <div class="block">
          <h2 class="block__h">{tr('product.sizes')}</h2>
          <ul class="sizes">
            {d.sizes.map((s) => (
              <li class="sizes__row">
                <span>{s.label}</span>
                <span class="price">{formatPrice(s.price)}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {d.fabrics.length > 0 && (
        <div class="block">
          <h2 class="block__h">{tr('product.options')}</h2>
          <ul class="tags">{d.fabrics.map((f) => <li class="pill">{f}</li>)}</ul>
        </div>
      )}

      {d.colors.length > 0 && (
        <div class="block">
          <h2 class="block__h">{lang === 'fr' ? 'Couleurs' : 'Colours'}</h2>
          <ul class="tags">{d.colors.map((c) => <li class="pill pill--ghost">{c}</li>)}</ul>
        </div>
      )}

      <div class="order">
        <a class="btn btn--wa order__btn" href={waHref} target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2Zm5.8 14.04c-.25.7-1.44 1.34-1.99 1.42-.51.08-1.15.11-1.86-.12-.43-.14-.98-.32-1.69-.62-2.97-1.28-4.91-4.27-5.06-4.47-.15-.2-1.21-1.61-1.21-3.07s.77-2.18 1.04-2.48c.27-.3.59-.37.79-.37l.57.01c.18.01.43-.07.67.51.25.6.84 2.06.91 2.21.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.18-.31.4-.45.53-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.02 1.12 1 2.07 1.31 2.36 1.46.3.15.47.12.64-.07.18-.2.74-.86.94-1.16.2-.3.4-.25.67-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.71-.18 1.4Z"/></svg>
          {tr('cta.order')}
        </a>
        <p class="order__note">
          <span class="pill pill--made">{tr('product.madeToOrder')}</span>
          {tr('product.orderNote')}
        </p>
      </div>
    </div>
  </div>
</section>

{related.length > 0 && (
  <section class="section related">
    <div class="wrap">
      <h2 class="related__h">{tr('product.related')}</h2>
      <div class="grid grid--related">
        {related.map((p, i) => <ProductCard product={p} lang={lang} index={i} />)}
      </div>
    </div>
  </section>
)}

<style>
  .crumbs { display: flex; gap: .6rem; flex-wrap: wrap; align-items: center; padding-top: 1.6rem; font-size: var(--step--1); color: var(--ink-soft); }
  .crumbs a:hover { color: var(--terracotta); }
  .crumbs__current { color: var(--ink); font-weight: 600; }

  .product__grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: start; }

  .gallery { position: sticky; top: 100px; }
  /* Whole product visible — no cropping: contained inside a soft rounded frame */
  .gallery__main { aspect-ratio: 1/1; background: var(--cream-deep); border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 24px 50px -30px rgba(43,36,32,.5); }
  .gallery__main img { width: 100%; height: 100%; object-fit: contain; padding: clamp(.8rem, 2.5vw, 1.8rem); }
  .gallery__thumbs { display: flex; gap: .8rem; flex-wrap: wrap; margin-top: 1.2rem; }
  /* Pebble-shaped thumbnails */
  .thumb { width: 74px; height: 74px; border-radius: 50%; overflow: hidden; box-shadow: 0 0 0 2px transparent; transition: box-shadow .2s, transform .2s; background: var(--cream-deep); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb:hover { transform: translateY(-2px); box-shadow: 0 0 0 2px var(--rose); }
  .thumb.is-active { box-shadow: 0 0 0 2.5px var(--terracotta); }

  .info__cat { display: inline-block; font-weight: 700; font-size: var(--step--1); text-transform: uppercase; letter-spacing: .12em; padding: .3em .9em; border-radius: 999px; color: var(--paper); }
  .info__cat--bebe { background: var(--bebe); }
  .info__cat--pet { background: var(--pet); }
  .info__title { font-size: var(--step-3); margin: .8rem 0 .4rem; }
  .info__price { font-size: var(--step-2); color: var(--terracotta); }
  .info__desc { font-size: var(--step-1); color: var(--ink-soft); margin: 1rem 0 1.6rem; max-width: 48ch; }

  .block { margin-bottom: 1.5rem; }
  .block__h { font-size: var(--step-0); text-transform: uppercase; letter-spacing: .1em; font-family: var(--font-body); font-weight: 700; color: var(--ink-soft); margin-bottom: .7rem; }
  .sizes { display: grid; gap: .2rem; max-width: 360px; }
  .sizes__row { display: flex; justify-content: space-between; gap: 1rem; padding: .6em 0; border-bottom: 1px dashed color-mix(in srgb, var(--ink) 20%, transparent); }
  .sizes__row .price { color: var(--terracotta); }
  .tags { display: flex; flex-wrap: wrap; gap: .5rem; }
  .pill--ghost { background: transparent; }
  .pill--made { background: var(--sage); color: var(--paper); box-shadow: none; margin-right: .5em; }

  .order { margin-top: 2rem; padding-top: 1.6rem; border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent); }
  .order__btn { font-size: var(--step-1); padding: .9em 1.8em; }
  .order__note { margin-top: 1rem; font-size: var(--step--1); color: var(--ink-soft); line-height: 1.7; }

  .related__h { font-size: var(--step-2); text-align: center; margin-bottom: 2rem; }
  .grid { display: grid; gap: clamp(1.1rem, 2.5vw, 2rem); }
  .grid--related { grid-template-columns: repeat(3, 1fr); }

  @media (max-width: 860px) {
    .product__grid { grid-template-columns: 1fr; }
    .gallery { position: static; }
    .grid--related { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  const main = document.getElementById('gallery-main') as HTMLImageElement | null;
  document.querySelectorAll<HTMLButtonElement>('.thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src;
      if (!src || !main) return;
      main.src = src;
      document.querySelectorAll('.thumb').forEach((t) => t.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });
</script>
