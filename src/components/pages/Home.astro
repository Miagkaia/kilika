---
import type { Lang } from '../../i18n/ui';
import { t, ui } from '../../i18n/ui';
import { localizedPath, waLink } from '../../lib/site';
import { featuredProducts } from '../../lib/products';
import homeData from '../../content/pages/home.json';
import ProductCard from '../ProductCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const p = (path: string) => localizedPath(path, lang);

const homeCopy = homeData[lang];
const featured = (await featuredProducts()).slice(0, 6);
const orderHref = waLink(ui[lang]['wa.generic']);

const marquee = lang === 'fr'
  ? ['Fait main en France', 'Double gaze', 'Liberty', 'Sur mesure', 'Paillettes', 'Cousu avec amour']
  : ['Handmade in France', 'Double gauze', 'Liberty', 'Made to measure', 'Sequins', 'Stitched with love'];
---
<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--2" aria-hidden="true"></div>

  <div class="wrap wrap-wide hero__grid">
    <div class="hero__text">
      <span class="pill hero__announce">{homeCopy.announce}</span>
      <h1 class="hero__title">
        <span>{tr('home.heroLine1')}</span>
        <span class="hero__title-accent">{tr('home.heroLine2')}</span>
        <span>{tr('home.heroLine3')}</span>
      </h1>
      <p class="hero__sub">{homeCopy.heroSub}</p>
      <div class="hero__cta">
        <a class="btn btn--accent" href={p('/bebe')}>{tr('cta.discoverBebe')}</a>
        <a class="btn btn--ghost" href={p('/chien-chat')}>{tr('cta.discoverPet')}</a>
      </div>
    </div>

    <div class="hero__art" aria-hidden="true">
      <figure class="hero__img hero__img--a blob"><img src="/brand/amb-bebe-1.webp" alt="" width="520" height="400" loading="eager" /></figure>
      <figure class="hero__img hero__img--b blob"><img src="/brand/hero-treasure.webp" alt="" width="420" height="350" loading="eager" /></figure>
      <figure class="hero__img hero__img--c blob"><img src="/brand/amb-bebe-2.webp" alt="" width="360" height="300" loading="lazy" /></figure>
      <span class="hero__sticker">♡</span>
    </div>
  </div>

  <div class="marquee hero__marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((w) => <span class="marquee__item">{w} <i>✶</i></span>)}
    </div>
  </div>
</section>

<!-- ===================== UNIVERSES ===================== -->
<section class="section universes">
  <div class="wrap">
    <header class="sec-head" data-reveal>
      <span class="eyebrow">{tr('home.tagline')}</span>
      <h2 class="sec-title">{tr('home.universesTitle')}</h2>
    </header>
    <div class="universes__grid">
      <a class="uni uni--bebe" href={p('/bebe')} data-reveal>
        <img src="/brand/uni-bebe.webp" alt="" width="700" height="800" loading="lazy" />
        <div class="uni__overlay">
          <h3>{tr('home.bebeName')}</h3>
          <p>{tr('home.bebeDesc')}</p>
          <span class="uni__link">{tr('cta.discover')} <i>→</i></span>
        </div>
      </a>
      <a class="uni uni--pet" href={p('/chien-chat')} data-reveal>
        <img src="/brand/uni-pet.webp" alt="" width="700" height="800" loading="lazy" />
        <div class="uni__overlay">
          <h3>{tr('home.petName')}</h3>
          <p>{tr('home.petDesc')}</p>
          <span class="uni__link">{tr('cta.discover')} <i>→</i></span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ===================== FEATURED ===================== -->
<section class="section featured">
  <div class="wrap">
    <header class="sec-head sec-head--row" data-reveal>
      <div>
        <span class="eyebrow">{tr('home.featured')}</span>
        <h2 class="sec-title">{lang === 'fr' ? 'Les pièces qu’on adore' : 'The pieces we love'}</h2>
      </div>
      <a class="btn btn--ghost sec-head__btn" href={p('/bebe')}>{tr('cta.seeAll')}</a>
    </header>
    <div class="grid grid--products">
      {featured.map((prod, i) => <ProductCard product={prod} lang={lang} index={i} />)}
    </div>
  </div>
</section>

<!-- ===================== FABRICS ===================== -->
<section class="section fabrics">
  <div class="wrap fabrics__inner">
    <figure class="fabrics__img blob" data-reveal>
      <img src="/brand/fabrics.webp" alt="" width="760" height="520" loading="lazy" />
    </figure>
    <div class="fabrics__text" data-reveal>
      <span class="eyebrow">{lang === 'fr' ? 'Les matières' : 'The fabrics'}</span>
      <h2 class="sec-title">{tr('home.fabricsTitle')}</h2>
      <p>{tr('home.fabricsDesc')}</p>
      <ul class="fabrics__list">
        {(lang === 'fr'
          ? ['Double gaze', 'Liberty', 'Paillettes', 'Bandana', 'Broderie sur mesure']
          : ['Double gauze', 'Liberty', 'Sequins', 'Bandana', 'Custom embroidery']
        ).map((f) => <li>{f}</li>)}
      </ul>
    </div>
  </div>
</section>

<!-- ===================== STORY TEASER ===================== -->
<section class="section story">
  <div class="wrap story__inner">
    <figure class="story__portrait blob" data-reveal>
      <img src="/brand/raphaelle.webp" alt="Raphaëlle, créatrice de Kilika" width="440" height="460" loading="lazy" />
    </figure>
    <div class="story__text" data-reveal>
      <span class="eyebrow">{tr('home.storyEyebrow')}</span>
      <h2 class="sec-title">{tr('home.madeTitle')}</h2>
      <p>{tr('home.madeDesc')}</p>
      <a class="btn" href={p('/a-propos')}>{tr('home.storyLink')}</a>
    </div>
  </div>
</section>

<style>
  .sec-head { text-align: center; max-width: 30ch; margin: 0 auto clamp(2rem, 5vw, 3.5rem); }
  .sec-head--row { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; max-width: none; text-align: left; }
  .sec-title { font-size: var(--step-3); margin-top: .6rem; }
  .sec-head__btn { flex: none; }
  .grid { display: grid; gap: clamp(1.1rem, 2.5vw, 2rem); }
  .grid--products { grid-template-columns: repeat(3, 1fr); }

  /* ---------- HERO ---------- */
  .hero { position: relative; overflow: hidden; padding-top: clamp(1rem, 3vw, 3rem); }
  .hero__blob { position: absolute; z-index: 0; filter: blur(8px); opacity: .5; border-radius: var(--blob); }
  .hero__blob--1 { width: 42vw; height: 42vw; left: -12vw; top: 8vw; background: radial-gradient(circle at 40% 40%, var(--rose-soft), transparent 70%); }
  .hero__blob--2 { width: 38vw; height: 38vw; right: -10vw; bottom: -6vw; background: radial-gradient(circle at 50% 50%, var(--pet-soft), transparent 70%); }
  .hero__grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1.05fr .95fr; align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem); padding-block: clamp(2rem, 5vw, 4.5rem);
  }
  .hero__announce { background: var(--paper); }
  .hero__title { font-size: var(--step-5); margin: 1.2rem 0; }
  .hero__title span { display: block; }
  .hero__title-accent { color: var(--terracotta); font-style: italic; font-weight: 500; margin-left: .4em; }
  .hero__sub { font-size: var(--step-1); max-width: 42ch; color: var(--ink-soft); }
  .hero__cta { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.8rem; }

  .hero__art { position: relative; aspect-ratio: 1 / 1; min-height: 340px; }
  .hero__img { position: absolute; box-shadow: 0 30px 60px -30px rgba(43,36,32,.55); }
  .hero__img img { width: 100%; height: 100%; object-fit: cover; }
  .hero__img--a { width: 62%; aspect-ratio: 5/4; top: 2%; right: 0; animation: float 7s ease-in-out infinite; }
  .hero__img--b { width: 52%; aspect-ratio: 6/5; bottom: 0; left: 0; animation: float 8s ease-in-out infinite reverse; z-index: 2; }
  .hero__img--c { width: 40%; aspect-ratio: 6/5; top: 38%; right: 6%; animation: float 9s ease-in-out infinite .5s; }
  .hero__sticker {
    position: absolute; top: 30%; left: 40%; z-index: 3; font-size: 2.2rem; color: var(--terracotta);
    background: var(--paper); width: 2em; height: 2em; display: grid; place-items: center; border-radius: 999px;
    box-shadow: 0 12px 28px -14px rgba(43,36,32,.6); animation: float 6s ease-in-out infinite;
  }
  @keyframes float { 0%,100% { transform: translateY(0) rotate(0); } 50% { transform: translateY(-14px) rotate(-1.5deg); } }
  @media (prefers-reduced-motion: reduce) { .hero__img, .hero__sticker { animation: none; } }

  .hero__marquee {
    margin-top: clamp(1rem, 3vw, 2rem); padding-block: .9rem; border-block: 2px solid var(--ink);
    background: var(--ochre); color: var(--ink); font-family: var(--font-display); font-size: var(--step-1);
  }
  .marquee__item { display: inline-flex; align-items: center; gap: 1.2rem; }
  .marquee__item i { color: var(--terracotta-deep); font-style: normal; }

  /* ---------- UNIVERSES ---------- */
  .universes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 2.5vw, 1.8rem); }
  .uni { position: relative; aspect-ratio: 5/6; border-radius: var(--radius-lg); overflow: hidden; display: block; }
  .uni img { width: 100%; height: 100%; object-fit: cover; transition: transform .9s cubic-bezier(.2,.8,.2,1); }
  .uni:hover img { transform: scale(1.06); }
  .uni__overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end;
    padding: clamp(1.4rem, 3vw, 2.6rem); color: var(--cream);
    background: linear-gradient(to top, rgba(43,36,32,.82) 0%, rgba(43,36,32,.25) 45%, transparent 75%);
  }
  .uni__overlay h3 { font-size: var(--step-3); }
  .uni__overlay p { max-width: 32ch; margin: .5rem 0 1rem; color: color-mix(in srgb, var(--cream) 90%, transparent); }
  .uni__link { font-weight: 700; display: inline-flex; gap: .5em; }
  .uni__link i { transition: transform .3s; }
  .uni:hover .uni__link i { transform: translateX(6px); }
  .uni--bebe .uni__overlay { background: linear-gradient(to top, color-mix(in srgb, var(--bebe) 88%, #2b2420) 0%, transparent 70%); }
  .uni--pet .uni__overlay { background: linear-gradient(to top, color-mix(in srgb, var(--pet) 90%, #2b2420) 0%, transparent 70%); }

  /* ---------- FABRICS ---------- */
  .fabrics { background: var(--cream-deep); border-radius: var(--radius-lg); margin-inline: var(--gutter); }
  .fabrics__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center; }
  .fabrics__img img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/3; }
  .fabrics__text .sec-title { font-size: var(--step-2); }
  .fabrics__text p { margin: 1rem 0 1.4rem; max-width: 44ch; color: var(--ink-soft); }
  .fabrics__list { display: flex; flex-wrap: wrap; gap: .6rem; }
  .fabrics__list li { background: var(--paper); padding: .4em 1em; border-radius: 999px; font-weight: 600; font-size: var(--step--1); }

  /* ---------- STORY ---------- */
  .story__inner { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(1.5rem, 4vw, 4rem); align-items: center; }
  .story__portrait { background: var(--bebe-soft); }
  .story__portrait img { width: 100%; aspect-ratio: 1/1; object-fit: cover; }
  .story__text .sec-title { font-size: var(--step-2); }
  .story__text p { margin: 1rem 0 1.6rem; max-width: 50ch; color: var(--ink-soft); }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__art { order: -1; max-width: 460px; margin-inline: auto; width: 100%; }
    .grid--products { grid-template-columns: repeat(2, 1fr); }
    .fabrics__inner, .story__inner { grid-template-columns: 1fr; }
    .story__portrait { max-width: 320px; }
    .sec-head--row { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 560px) {
    .universes__grid { grid-template-columns: 1fr; }
    .hero__title { font-size: clamp(3rem, 14vw, 4.5rem); }
  }
</style>
