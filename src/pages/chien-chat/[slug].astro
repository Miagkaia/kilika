---
import Base from '../../layouts/Base.astro';
import Product from '../../components/pages/Product.astro';
import { productsByCategory, title as pTitle, desc as pDesc } from '../../lib/products';

export async function getStaticPaths() {
  const products = await productsByCategory('pet');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}
const { product } = Astro.props;
---
<Base
  lang="fr"
  title={pTitle(product, 'fr')}
  description={pDesc(product, 'fr')}
  altPath={`/en/chien-chat/${product.id}`}
>
  <Product lang="fr" product={product} />
</Base>
